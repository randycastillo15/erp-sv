# Variables de entorno del DTE Gateway — copiar a .env y completar con valores reales
# NUNCA commitear .env (está en .gitignore)

# ── Ambiente ──────────────────────────────────────────────────────────────────
# 00 = Pruebas (MH homologación)  |  01 = Producción
DTE_AMBIENTE=00

# ── NIT del emisor ────────────────────────────────────────────────────────────
# 14 dígitos sin guiones (NIT) o 9 dígitos sin guión (DUI homologado)
NIT_EMISOR=

# ── Firmador SVFE ─────────────────────────────────────────────────────────────
# URL del servicio de firma — usar host.docker.internal si el firmador corre en el host
FIRMADOR_URL=http://host.docker.internal:8113/firmardocumento/
# Contraseña de la clave privada del certificado de firma
FIRMADOR_PASSWORD_PRI=

# ── API MH ────────────────────────────────────────────────────────────────────
# Contraseña del API MH para obtener el token Bearer
# PRUEBAS:     mh.factura.gob.sv/nph-bin/MHConsulta/...
# PRODUCCIÓN:  factura.gob.sv/nph-bin/MHConsulta/...  (confirmar URL oficial)
MH_API_PASSWORD=

# ── Logging ───────────────────────────────────────────────────────────────────
# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Base de datos idempotencia ────────────────────────────────────────────────
# Ruta al archivo SQLite de idempotencia. Hacer backup antes de actualizaciones.
# DTE_STORE_PATH=/app/data/dte_store.db   # descomentar para ruta personalizada
